{
	"hooks": {
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "http",
						"url":"http://localhost:9093/hooks/tool",
						"headers":{
						   "X-MCPC-SESSION-ID":"$MCPC_SESSION_ID"
						},
						"allowedEnvVars":[
						   "MCPC_SESSION_ID"
						],
						"timeout": 86400
					}
				]
			}
		],
		"PermissionRequest": [
			{
				"hooks": [
					{
						"type": "http",
						"url":"http://localhost:9093/hooks/permission",
						"headers":{
						   "X-MCPC-SESSION-ID":"$MCPC_SESSION_ID"
						},
						"allowedEnvVars":[
						   "MCPC_SESSION_ID"
						],
						"timeout": 86400
					}
				]
			}
		]
	}
}