{
	"env": {
		"ENABLE_CLAUDEAI_MCP_SERVERS": "false",
		"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
		"CLAUDE_CODE_ALT_SCREEN_FULL_REPAINT": "1",
		"CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "1",
		"DISABLE_COMPACT": "1",
		"ENABLE_TOOL_SEARCH": "false"
	},
	"includeGitInstructions": false,
	"permissions": {
		"deny": [
			"___*",
			"NotebookEdit",
			"PowerShell",
			"_Agent",
			"Agent(Explore)",
			"Agent(Plan)",
			"Agent(general-purpose)",
			"Agent(claude-code-guide)",
			"Agent(statusline-setup)",
			"Workflow",
			"ScheduleWakeup",
			"ShareOnboardingGuide",
			"CronCreate",
			"CronDelete",
			"CronList",
			"EnterPlanMode",
			"ExitPlanMode",
			"EnterWorktree",
			"ExitWorktree",
			"ListMcpResourcesTool",
			"ReadMcpResourceTool",
			"WaitForMcpServers",
			"PushNotification",
			"RemoteTrigger",
			"SendMessage",
			"DesignSync",
			"_WebFetch",
			"_WebSearch",
			"mcp__claude_ai_*",
			"Monitor",
			"TaskCreate",
			"TaskGet",
			"TaskList",
			"TaskUpdate",
			"TaskStop",
			"TaskOutput",
			"_Bash",
			"_Read",
			"_Edit",
			"_Write",
			"AskUserQuestion",
			"ToolSearch",
			"_Grep",
			"_Glob",
			"Bash(git commit *)",
			"Bash(git commit)",
			"Bash(git push *)",
			"Bash(git push)",
			"Bash(git add *)",
			"Bash(git add)",
			"Bash(git merge *)",
			"Bash(git rebase *)",
			"Bash(git reset *)",
			"Bash(git revert *)",
			"Bash(git rm *)",
			"Bash(git mv *)",
			"Bash(git tag *)",
			"Bash(git stash *)",
			"Bash(git cherry-pick *)",
			"Bash(git fetch *)",
			"Bash(git pull *)",
			"Bash(git restore *)",
			"Bash(git switch *)",
			"Bash(git checkout *)",
			"Bash(git branch -d *)",
			"Bash(git branch -D *)",
			"Bash(git branch -m *)",
			"Bash(git clean *)"
		],
		"allow": [
			"Bash(savecopy.sh *)"
		],
		"defaultMode": "default",
		"additionalDirectories": [
			"/tmp/claude-1000"
		]
	},
	"model": "opus",
	"disableBundledSkills": true,
	"disableAgentView": true,
	"disableRemoteControl": true,
	"enableWorkflows": false,
	"workflowKeywordTriggerEnabled": false,
	"respondToBashCommands": false,
	"allowAllClaudeAiMcps": false,
	"statusLine": {
		"type": "command",
		"command": "~/.claude-personal/statusline.sh",
		"padding": 0
	},
	"skipWebFetchPreflight": true,
	"spinnerTipsEnabled": false,
	"spinnerVerbs": {
		"mode": "replace",
		"verbs": [
			"Processing"
		]
	},
	"effortLevel": "high",
	"promptSuggestionEnabled": false,
	"awaySummaryEnabled": false,
	"voice": {
		"enabled": false
	},
	"allowedChannelPlugins": [],
	"prefersReducedMotion": true,
	"autoMemoryEnabled": false,
	"showThinkingSummaries": false,
	"disableAutoMode": "disable",
	"claudeMdExcludes": [
		"**"
	],
	"theme": "light-daltonized",
	"verbose": true,
	"autoCompactEnabled": false,
	"switchModelsOnFlag": false,
	"showTurnDuration": false,
	"disableDeepLinkRegistration": "disable",
	"alwaysCopyFullResponse": true
}