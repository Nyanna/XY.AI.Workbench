{
	"hooks": {
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/tool_deny.sh",
						"timeout": 86400
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/spell-check.sh",
						"timeout": 86400
					}
				]
			}
		]
	}
}